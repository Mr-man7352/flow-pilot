generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ChatSession {
  id        String   @id @default(cuid())
  userId    String
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model AuditLog {
  id          String   @id @default(cuid())
  workflowId  String
  action      String   // "activated", "deactivated", "workflow_created", "workflow_create_failed"
  description String?  // original natural-language description (US-08)
  metadata    Json?    // { jsonHash, status, error? } (US-08)
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}

model WorkflowExecution {
  id          String    @id @default(cuid())
  workflowId  String    @map("workflow_id")
  executionId String?   @map("execution_id") // n8n execution ID
  status      String    @map("status")        // "running" | "success" | "error" | "unknown" | "timeout"
  startedAt   DateTime  @default(now()) @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  result      Json?     @map("result")        // execution output data or error message

  @@map("workflow_executions")
}
